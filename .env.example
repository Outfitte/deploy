# ── Frontend ─────────────────────────────────────────────────────────────────
# Port exposed by the Nginx container (single public entry point).
PORT=30080

# ── Backend ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080
APP_ENV=production
MEDIA_STORAGE_PATH=/data/media
LOG_LEVEL=info

# Required. Must be a securely generated random string, minimum 32 characters.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Database — sqlite is the default
# DB_DSN is the path to the SQLite database file
DB_DRIVER=sqlite
DB_DSN=/data/outfitte.db

# URL of the backend API server used by the nginx proxy (Docker) and Vite dev proxy (local dev).
BACKEND_URL=http://backend:8080

# ── Local development (without Docker) ────────────────────────────────────────
# Override BACKEND_URL to point at your local backend:
#   BACKEND_URL=http://localhost:8080 npm run dev
